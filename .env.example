# 101 Digital identity server used by src/app/login/actions.ts for the
# POST /oauth2/token password-grant call. Server-only — never expose
# client_secret to the browser (no NEXT_PUBLIC_ prefix).
IDENTITY_SERVER_URL=
IDENTITY_CLIENT_ID=
IDENTITY_CLIENT_SECRET=

# Base URL for the browser-side API client (src/api/http/client.ts).
# Public (NEXT_PUBLIC_) because it's read in the browser bundle. Leave
# unset to default to same-origin "/api".
NEXT_PUBLIC_API_BASE_URL=

# 101 Digital neobank API, used by src/app/api/users/me/route.ts to proxy
# GET /membership-service/1.0.0/users/me. Server-only (the Route Handler
# runs on the server) — no NEXT_PUBLIC_ prefix needed.
NEOBANK_API_BASE_URL=
