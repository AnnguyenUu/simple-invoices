# 101 Digital identity server used by src/modules/login/repository/login.ts
# for the POST /oauth2/token password-grant call (and the follow-up
# membership-service call to fetch the org token). Server-only — never
# expose client_secret to the browser (no NEXT_PUBLIC_ prefix).
IDENTITY_SERVER_URL=
IDENTITY_CLIENT_ID=
IDENTITY_CLIENT_SECRET=

# Base URL for the browser-side API client (src/api/http/client.ts).
# Public (NEXT_PUBLIC_) because it's read in the browser bundle. Leave
# unset to default to same-origin "/api".
NEXT_PUBLIC_API_BASE_URL=

# 101 Digital neobank API gateway (membership-service, invoice-service),
# used by src/api/http/neobank-proxy.ts — the single function every
# src/app/api/*/route.ts handler calls to proxy a request upstream.
# Server-only (Route Handlers run on the server) — no NEXT_PUBLIC_ prefix.
NEOBANK_API_BASE_URL=
